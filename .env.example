# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=subs_development
MYSQL_USER=subs_user
MYSQL_PASSWORD=subs_password

# Rails DB接続 (コンテナ名 db を指定)
DATABASE_USER=subs_user
DATABASE_PASSWORD=subs_password
DATABASE_HOST=db
DATABASE_NAME=subs_development
DATABASE_NAME_TEST=subs_test

# CORS: フロントエンドのオリジンを指定
FRONTEND_ORIGIN=http://localhost:5173

# Rails (rails secret で生成してください)
SECRET_KEY_BASE=replace_with_output_of_rails_secret

# Supabase Storage (Supabase ダッシュボード → Project Settings → API で確認)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
